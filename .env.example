# ──────────────────────────────────────────────────────────────────────────────
# EGA DPP Platform — local development environment
# Copy to .env (root) and adjust per-developer values.
# Production secrets are managed via the deployment environment, never committed.
# ──────────────────────────────────────────────────────────────────────────────

# Environment selector: development | staging | production
DPP_ENV=development

# Default tenant for local development. Tenant-id 1 is reserved for EGA.
DPP_DEFAULT_TENANT_ID=1
DPP_DEFAULT_TENANT_SLUG=ega

# ──────────────────────────────────────────────────────────────────────────────
# Postgres 17 — primary system of record
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dpp
POSTGRES_USER=dpp
POSTGRES_PASSWORD=dpp_local_dev_only

# Async URL used by SQLAlchemy 2.0
DATABASE_URL=postgresql+asyncpg://dpp:dpp_local_dev_only@localhost:5432/dpp

# Sync URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://dpp:dpp_local_dev_only@localhost:5432/dpp

# ──────────────────────────────────────────────────────────────────────────────
# Redis 7 — hot-path cache + rate limiting
# ──────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# DPP issuer identity (did:web + Ed25519)
# In production, the private key lives in HSM/KMS, never in env.
# ──────────────────────────────────────────────────────────────────────────────
DPP_ISSUER_DID=did:web:dpp.ega.local
DPP_ISSUER_KEY_PATH=./infra/dev-keys/issuer-ed25519.pem
DPP_ISSUER_PUBLIC_KEY_PATH=./infra/dev-keys/issuer-ed25519.pub.pem

# ──────────────────────────────────────────────────────────────────────────────
# Resolver / public viewer
# ──────────────────────────────────────────────────────────────────────────────
DPP_RESOLVER_BASE_URL=http://localhost:3000
DPP_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_RESOLVER_BASE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# CORS / allowed origins (comma-separated)
# ──────────────────────────────────────────────────────────────────────────────
DPP_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────────────
DPP_LOG_LEVEL=INFO
DPP_LOG_FORMAT=json
OTEL_SERVICE_NAME=dpp-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# ──────────────────────────────────────────────────────────────────────────────
# Feature flags (per-environment overrides)
# ──────────────────────────────────────────────────────────────────────────────
DPP_FEATURE_DLT_ANCHOR=false
DPP_FEATURE_WORKSHOP_MODE=true
DPP_FEATURE_CBAM_EXPORT=false
