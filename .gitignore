# Node / pnpm / Turborepo
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
.turbo/
dist/
build/
out/
.next/
.vercel/
*.tsbuildinfo
coverage/
.nyc_output/

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ──────────────────────────────────────────────────────────────────────────────
# Environment & secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
!packages/**/keys/example.*.pem
secrets/

# ──────────────────────────────────────────────────────────────────────────────
# Logs & databases
# ──────────────────────────────────────────────────────────────────────────────
*.log
logs/
*.sqlite
*.sqlite3
*.db
postgres-data/
redis-data/
minio-data/

# ──────────────────────────────────────────────────────────────────────────────
# Generated artifacts (committed-by-codegen, not by hand)
