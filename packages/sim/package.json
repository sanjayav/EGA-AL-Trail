{
  "name": "@dpp/sim",
  "version": "0.1.0",
  "private": true,
  "description": "DPP simulator — emit canonical cast events from EGA-anchored presets. CLI + library.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "dpp-sim": "./bin/dpp-sim.mjs"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "fire": "node --import tsx bin/dpp-sim.mjs fire",
    "list": "node --import tsx bin/dpp-sim.mjs list",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dpp/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
