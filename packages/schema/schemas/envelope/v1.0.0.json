{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dpp.ega.ae/envelope/v1.0.0.json",
  "title": "Signed DPP Envelope (W3C VC 2.0)",
  "description": "W3C Verifiable Credential 2.0 envelope wrapping a canonical DPP record. Signed with the issuer DID's Ed25519 key per the Ed25519Signature2020 suite.",
  "type": "object",
  "additionalProperties": false,
  "required": ["@context", "type", "issuer", "validFrom", "credentialSubject", "proof"],
  "properties": {
    "@context": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "minItems": 2,
      "contains": { "const": "https://www.w3.org/ns/credentials/v2" }
    },
    "id": {
      "type": "string",
      "format": "uri",
      "description": "Stable URI for this credential — typically the GS1 Digital Link of the DPP"
    },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "contains": { "const": "VerifiableCredential" },
      "description": "Must include 'VerifiableCredential' and 'DigitalProductPassport'"
    },
    "issuer": {
      "oneOf": [
        { "type": "string", "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._:%-]+$" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string", "pattern": "^did:[a-z0-9]+:[a-zA-Z0-9._:%-]+$" },
            "name": { "type": "string" }
          }
        }
      ]
    },
    "validFrom": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "dpp"],
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "dpp": { "$ref": "https://schemas.dpp.ega.ae/dpp/v1.0.0.json" }
      }
    },
    "credentialStatus": {
      "type": "object",
      "description": "Status reference — supports revocation lists and DLT anchors"
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "created", "verificationMethod", "proofPurpose", "proofValue"],
      "properties": {
        "type": {
          "type": "string",
          "const": "Ed25519Signature2020"
        },
        "created": { "type": "string", "format": "date-time" },
        "verificationMethod": {
          "type": "string",
          "description": "DID URL identifying the public key, e.g. did:web:dpp.ega.ae#key-1"
        },
        "proofPurpose": {
          "type": "string",
          "enum": ["assertionMethod"]
        },
        "proofValue": {
          "type": "string",
          "description": "Multibase-encoded Ed25519 signature (z…)"
        }
      }
    }
  }
}
